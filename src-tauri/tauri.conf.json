{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "jsonnodebuilder",
  "version": "0.1.0",
  "identifier": "com.shiin.jsonnodebuilder",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "jsonnodebuilder",
        "width": 1440,
        "height": 810,
        "minWidth": 1200,
        "minHeight": 675,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
