{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "JsonNodeBuilder",
  "version": "1.0.0",
  "identifier": "com.alierkitten.jsonnodebuilder",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "JsonNodeBuilder",
        "width": 1280,
        "height": 720,
        "minWidth": 853,
        "minHeight": 480,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
